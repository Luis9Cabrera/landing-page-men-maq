---
import '../styles/global.css';

const { title = 'Menmaq | Máquinas Bloqueras' } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Menmaq — Máquinas bloqueras de alto rendimiento. Equipos robustos, eficientes y fáciles de operar para producción de bloques, adoquines y bovedillas. Cotiza ahora." />
    <meta name="theme-color" content="#375c76" />
    <link rel="icon" type="image/svg+xml" href="/logos/logo.svg" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
